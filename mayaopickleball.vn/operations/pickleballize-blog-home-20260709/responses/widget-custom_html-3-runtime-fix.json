  "rendered": "<div id=\"custom_html-3\" class=\"widget_text col pb-0 widget widget_custom_html\"><span class=\"widget-title\">Thông tin liên hệ</span><div class=\"is-divider small\"></div><div class=\"textwidget custom-html-widget\"><h2>🏢\r\nMAY ÁO PICKLEBALL - VN</h2>\r\n<p>📍 \r\nMiền Bắc: 6 Ngõ 50 Nguyễn Hữu Thọ, Hoàng Liệt, Hà Nội\r\n</p>\r\n<p>📍 Miền Nam: 86/10 đường 12, P.Tam Bình, Thủ Đức, TP.HCM</p>\r\n\r\n<p>📞 Hotline: 0989.353.247</p>\r\n\r\n<p>📧 Email: x24sport.vn@gmail.com</p>\r\n\r\n<p>🕐 Thời gian làm việc: 8h00 – 20h00 (Tất cả các ngày trong tuần)</p>\n\n<script id=\"x24-pickleball-footer-fix\">\n(function(){\n  var textReplacements = [\n    [/May Áo Chạy Bộ/g,'May Áo Pickleball'],[/MAY ÁO CHẠY BỘ/g,'MAY ÁO PICKLEBALL'],[/Áo Chạy Bộ/g,'Áo Pickleball'],[/ÁO CHẠY BỘ/g,'ÁO PICKLEBALL'],[/áo chạy bộ/g,'áo pickleball'],[/Chạy Bộ/g,'Pickleball'],[/chạy bộ/g,'pickleball'],[/Giải Chạy/g,'Giải Giao Hữu Pickleball'],[/giải chạy/g,'giải giao hữu pickleball'],[/Đội Chạy/g,'Đội Pickleball'],[/đội chạy/g,'đội pickleball'],[/Runner/g,'người chơi pickleball'],[/runner/g,'người chơi pickleball'],[/Running/g,'Pickleball'],[/running/g,'pickleball'],[/Marathon/g,'Giải Pickleball'],[/marathon/g,'giải pickleball'],[/cung đường/g,'mặt sân'],[/bước chạy/g,'pha bóng'],[/Logo Đội Pickleball/g,'Logo Đội Pickleball']\n  ];\n  function fixText(s){ textReplacements.forEach(function(pair){ s=s.replace(pair[0],pair[1]); }); return s; }\n  function fixHref(h){\n    if(!h) return h;\n    return h\n      .replace('https://mayaochaybo.vn','https://mayaopickleball.vn')\n      .replace('http://mayaochaybo.vn','https://mayaopickleball.vn')\n      .replace('facebook.com/mayaochaybo','facebook.com/mayaopickleball')\n      .replace('m.me/mayaochaybo.vn','m.me/mayaopickleball.vn')\n      .replace(/may-ao-chay-bo-thiet-ke-rieng-x24/g,'ao-pickleball-thiet-ke-rieng')\n      .replace(/ao-chay-bo-co-tay/g,'ao-pickleball')\n      .replace(/ao-chay-bo-sat-nach/g,'shop/?s=pickleball+khong+tay')\n      .replace(/ao-chay-bo-co-do-sao-vang/g,'shop/?s=ao+pickleball+co+do+sao+vang')\n      .replace(/logo-doi-chay/g,'shop/?s=logo+pickleball')\n      .replace(/ao-chay-bo[^/?#]*/g,'shop/?s=pickleball');\n  }\n  function fix(){\n    var walker=document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {acceptNode:function(n){\n      var p=n.parentNode && n.parentNode.nodeName; return /^(SCRIPT|STYLE|NOSCRIPT|TEXTAREA|INPUT)$/.test(p) ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT;\n    }});\n    var nodes=[]; while(walker.nextNode()) nodes.push(walker.currentNode);\n    nodes.forEach(function(n){ var v=fixText(n.nodeValue); if(v!==n.nodeValue) n.nodeValue=v; });\n    document.querySelectorAll('a[href]').forEach(function(a){ var h=fixHref(a.getAttribute('href')); if(h) a.setAttribute('href',h); });\n    document.querySelectorAll('img[alt],input[placeholder]').forEach(function(el){ ['alt','placeholder','title','aria-label'].forEach(function(attr){ if(el.hasAttribute(attr)) el.setAttribute(attr, fixText(el.getAttribute(attr))); }); });\n  }\n  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',fix); else fix();\n})();\n</script></div></div>",
