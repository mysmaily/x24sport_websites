function x24_render_size_table($title, $sizes, $rows, $open = false) {
    ?>
    <details class="x24-size-table" <?php echo $open ? 'open' : ''; ?>>
        <summary>
            <span><?php echo esc_html($title); ?></span>
            <span class="x24-size-table__toggle" aria-hidden="true">Xem thông số</span>
        </summary>
        <div class="x24-size-table__scroll" tabindex="0" role="region" aria-label="<?php echo esc_attr($title); ?>">
            <table>
                <caption class="screen-reader-text"><?php echo esc_html($title); ?></caption>
                <thead>
                    <tr>
                        <th scope="col">Size</th>
                        <?php foreach ($sizes as $size) : ?>
                            <th scope="col"><?php echo esc_html($size); ?></th>
                        <?php endforeach; ?>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($rows as $label => $values) : ?>
                        <tr>
                            <th scope="row"><?php echo esc_html($label); ?></th>
                            <?php foreach ($values as $value) : ?>
                                <td><?php echo esc_html($value); ?></td>
                            <?php endforeach; ?>
                        </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    </details>
    <?php
}

// === Fabric page: inject remixicon via wp_head (bypass Autoptimize) ===
add_action("wp_head", "x24_fabric_remixicon", 20);
function x24_fabric_remixicon() {
    if (is_singular("page") && is_page("chat-lieu-vai")) {
        echo "<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css\">\n";
    }
}



// === Zoomable image viewer for fabric page (mayaochaybo.vn/chat-lieu-vai/) ===
// Hook at template_redirect priority 1 (before Autoptimize's buffer at priority 2)
// to disable JS optimization and enqueue the lightbox script.
add_action("template_redirect", "x24_fabric_lightbox_setup", 1);
function x24_fabric_lightbox_setup() {
    if (!is_singular("page") || !is_page("chat-lieu-vai")) {
        return;
    }
    add_filter("autoptimize_filter_js_noptimize", "__return_true");
    $relative_path = "/x24-fabric-lightbox.js";
    $absolute_path = get_stylesheet_directory() . $relative_path;
    wp_enqueue_script(
        "x24-fabric-lightbox",
        get_stylesheet_directory_uri() . $relative_path,
        array(),
        file_exists($absolute_path) ? (string) filemtime($absolute_path) : null,
        true
    );
}
