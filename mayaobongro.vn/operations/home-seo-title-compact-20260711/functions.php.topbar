/**
 * Product detail conversion panel.
 *
 * Replaces legacy short descriptions that contain document-level markup with
 * a consistent, accessible sales panel. Review data always comes from
 * WooCommerce and is never fabricated.
 */
add_filter('woocommerce_short_description', 'x24_product_detail_conversion_panel', 999);
function x24_product_detail_conversion_panel($description) {
    if (is_admin() && !wp_doing_ajax()) {
        return $description;
    }

    global $product;
    if (!$product instanceof WC_Product) {
        $product = wc_get_product(get_queried_object_id());
    }
    if (!$product instanceof WC_Product) {
        return $description;
    }

    $review_count = (int) $product->get_review_count();
    $average      = (float) $product->get_average_rating();

    ob_start();
    ?>
    <section class="x24-product-panel" aria-label="Tư vấn đặt may áo bóng rổ">
        <div class="x24-product-panel__intro">
            <div>
                <p class="x24-product-panel__label">May theo thiết kế riêng</p>
                <h2>Ưu đãi dành cho đội nhóm</h2>
            </div>
            <?php if ($review_count > 0) : ?>
                <a class="x24-product-panel__rating" href="#tab-reviews">
                    <span aria-hidden="true">★</span>
                    <?php echo esc_html(number_format_i18n($average, 1)); ?>/5
                    <small><?php echo esc_html(sprintf('(%d đánh giá)', $review_count)); ?></small>
                </a>
            <?php else : ?>
                <span class="x24-product-panel__trust">Thiết kế miễn phí theo yêu cầu</span>
            <?php endif; ?>
        </div>

        <ul class="x24-product-benefits">
            <li>Miễn phí thiết kế logo và slogan riêng</li>
            <li>In nhiệt sắc nét, bền màu, không bong tróc</li>
            <li>Hoàn thiện nhanh từ 1-2 ngày tùy đơn hàng</li>
            <li>Đủ kích cỡ cho nam, nữ và trẻ em</li>
        </ul>

        <div class="x24-product-actions" aria-label="Liên hệ đặt may">
            <a class="x24-product-actions__zalo" href="https://zalo.me/0989353247" target="_blank" rel="noopener">
                Tư vấn qua Zalo
            </a>
            <a class="x24-product-actions__phone" href="tel:0989353247">
                Gọi 0989.353.247
            </a>
        </div>
        <p class="x24-product-panel__note">Giá và ưu đãi được xác nhận theo số lượng, chất liệu và yêu cầu in.</p>
    </section>
    <?php
    return trim((string) ob_get_clean());
}

