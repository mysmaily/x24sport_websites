    $data['name']        = 'Mayaobongro.vn - Xưởng May Áo Bóng Rổ';
    $data['description'] = 'Xưởng may áo bóng rổ trực tiếp, thiết kế riêng miễn phí cho đội nhóm, câu lạc bộ và giải đấu bóng rổ';
    $data['telephone']   = '+84989353247';
    $data['address']     = [
        '@type'           => 'PostalAddress',
        'streetAddress'   => '1090/22D Quang Trung, Phường 14',
        'addressLocality' => 'Gò Vấp',
        'addressRegion'   => 'TP. Hồ Chí Minh',
        'addressCountry'  => 'VN',
    ];
    return $data;
}

// ============================================================
// 4. SEO HYGIENE - Noindex demo/thin URLs and improve archives/posts
// ============================================================
function x24_seo_is_demo_page($post = null) {
    $post = get_post($post);
    if (!$post instanceof WP_Post) {
        return false;
    }

    $protected_page_ids = array_filter([
        (int) get_option('page_on_front'),
        (int) get_option('page_for_posts'),
    ]);
    if (in_array((int) $post->ID, $protected_page_ids, true)) {
        return false;
    }

    if (in_array($post->post_type, ['blocks', 'featured_item'], true)) {
        return true;
    }

    if ($post->post_type !== 'page') {
        return false;
    }

    $path = trim((string) get_page_uri($post), '/');
    return $path === 'test'
        || $path === 'trang-mau'
        || $path === 'elements'
        || str_starts_with($path, 'elements/')
        || $path === 'demos'
        || str_starts_with($path, 'demos/');
}

function x24_seo_should_noindex_current_url() {
    if (is_admin()) {
        return false;
    }

    if (is_front_page() || is_home()) {
        return false;
    }

    if (is_singular()) {
        return x24_seo_is_demo_page(get_queried_object_id());
    }

    if (is_author() || is_tag() || is_tax('product_tag')) {
        return true;
    }

    if (is_post_type_archive(['blocks', 'featured_item'])) {
        return true;
    }

    return false;
}

add_filter('wpseo_robots', 'x24_seo_noindex_thin_urls', 999);
function x24_seo_noindex_thin_urls($robots) {
    if (!x24_seo_should_noindex_current_url()) {
        return $robots;
    }

    return 'noindex, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
}

add_filter('wpseo_sitemap_exclude_post_type', 'x24_seo_exclude_demo_post_types_from_sitemap', 10, 2);
function x24_seo_exclude_demo_post_types_from_sitemap($excluded, $post_type) {
    if (in_array($post_type, ['blocks', 'featured_item'], true)) {
        return true;
    }

    return $excluded;
}

add_filter('wpseo_sitemap_exclude_taxonomy', 'x24_seo_exclude_thin_taxonomies_from_sitemap', 10, 2);
function x24_seo_exclude_thin_taxonomies_from_sitemap($excluded, $taxonomy) {
    if (in_array($taxonomy, ['post_tag', 'product_tag', 'featured_item_category'], true)) {
        return true;
    }

    return $excluded;
}

add_filter('wpseo_sitemap_entry', 'x24_seo_filter_demo_sitemap_entries', 10, 3);
function x24_seo_filter_demo_sitemap_entries($url, $type, $object) {
    if (is_object($object) && isset($object->ID) && x24_seo_is_demo_page((int) $object->ID)) {
        return false;
    }

    if (is_array($url) && isset($url['loc'])) {
        $loc = (string) $url['loc'];
        if (str_contains($loc, '/elements/') || str_contains($loc, '/demos/') || str_contains($loc, '/test/') || str_contains($loc, '/trang-mau/') || str_contains($loc, '/author/')) {
            return false;
        }
    }

    return $url;
}

add_filter('wpseo_schema_graph', 'x24_seo_add_blogposting_schema', 20, 2);
function x24_seo_add_blogposting_schema($graph, $context) {
    if (!is_singular('post')) {
        return $graph;
    }

    $post_id = get_queried_object_id();
    $image_id = get_post_thumbnail_id($post_id);
    $author_id = (int) get_post_field('post_author', $post_id);

    $article = [
        '@type' => 'BlogPosting',
        '@id' => get_permalink($post_id) . '#article',
        'isPartOf' => [
            '@id' => get_permalink($post_id) . '#webpage',
        ],
        'headline' => wp_strip_all_tags(get_the_title($post_id)),
        'datePublished' => get_the_date(DATE_W3C, $post_id),
        'dateModified' => get_the_modified_date(DATE_W3C, $post_id),
        'mainEntityOfPage' => [
            '@id' => get_permalink($post_id) . '#webpage',
        ],
        'author' => [
            '@type' => 'Person',
            'name' => get_the_author_meta('display_name', $author_id),
        ],
        'publisher' => [
            '@id' => $context->site_url . '#organization',
        ],
    ];

    if ($image_id) {
        $image_url = wp_get_attachment_image_url($image_id, 'full');
        if ($image_url) {
            $article['image'] = [
                '@type' => 'ImageObject',
                'url' => $image_url,
            ];
        }
    }

    $graph[] = $article;
    return $graph;
}

