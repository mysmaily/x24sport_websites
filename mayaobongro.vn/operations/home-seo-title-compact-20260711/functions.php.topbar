// ============================================================
// PERFORMANCE OPTIMIZATIONS v2 — Added 2026-07-02
// (Only additions not already handled by existing functions)
// ============================================================

// 1. REMOVE UNNECESSARY WP HEAD TAGS
remove_action('wp_head', 'wp_generator');
remove_action('wp_head', 'wlwmanifest_link');
remove_action('wp_head', 'rsd_link');
remove_action('wp_head', 'wp_shortlink_wp_head');
remove_action('wp_head', 'rest_output_link_wp_head');
remove_action('wp_head', 'wp_oembed_add_discovery_links');
remove_action('wp_head', 'adjacent_posts_rel_link_wp_head');

// 2. REMOVE WP VERSION QUERY STRINGS FROM ASSETS
add_filter('style_loader_src', 'x24_perf_remove_version', 9999);
add_filter('script_loader_src', 'x24_perf_remove_version', 9999);
function x24_perf_remove_version($src) {
    if (strpos($src, 'ver=') !== false) {
        $src = remove_query_arg('ver', $src);
    }
    return $src;
}

// 3. DEFER ADDITIONAL RENDER-BLOCKING SCRIPTS
// (Existing x24_defer_safe_scripts handles CF7/WooCommerce — this adds more)
add_filter('script_loader_tag', 'x24_perf_defer_extra', 25, 3);
function x24_perf_defer_extra($tag, $handle, $src) {
    if (is_admin() || false !== strpos($tag, ' defer') || false !== strpos($tag, ' async')) {
        return $tag;
    }
    // Additional scripts to defer (not covered by existing function)
    $extra_defer = array(
        'jquery-migrate',
        'jquery-blockui',
        'js-cookie',
        'wc-add-to-cart-variation',
        'wc-single-product',
        'zoom',
        'flexslider',
        'flatsome-js',
        'flatsome-masonry-js',
        'ux-core-js',
    );
    if (in_array($handle, $extra_defer, true)) {
        return str_replace('<script ', '<script defer ', $tag);
    }
    return $tag;
}

// 4. PRELOAD CRITICAL CSS
add_action('wp_head', 'x24_perf_preload_css', 1);
function x24_perf_preload_css() {
    echo '<link rel="preload" as="style" href="' . get_template_directory_uri() . '/assets/css/flatsome.css" />';
    echo "\n";
    echo '<link rel="preload" as="style" href="' . get_stylesheet_directory_uri() . '/style.css" />';
    echo "\n";
}

// 5. ADD HSTS HEADER (via PHP since nginx is behind Cloudflare)
add_action('send_headers', 'x24_perf_hsts_header');
function x24_perf_hsts_header() {
    if (is_ssl() || isset($_SERVER['HTTP_X_FORWARDED_PROTO']) && $_SERVER['HTTP_X_FORWARDED_PROTO'] === 'https') {
        header('Strict-Transport-Security: max-age=31536000; includeSubDomains; preload');
    }
}

/**
 * Product hero data and layout.
 *
 * The model code is editable in Product data > General. Product colors use the
 * global WooCommerce attribute "Màu sắc" so they can be filtered later.
 */
add_action('woocommerce_product_options_general_product_data', 'x24_product_model_code_field');
function x24_product_model_code_field() {
    woocommerce_wp_text_input(
        array(
            'id'          => '_x24_model_code',
            'label'       => 'Mã mẫu',
            'placeholder' => 'Ví dụ: X24-CB-064',
            'desc_tip'    => true,
            'description' => 'Mã hiển thị trên trang chi tiết sản phẩm.',
        )
    );
}

add_action('woocommerce_process_product_meta', 'x24_save_product_model_code_field');
function x24_save_product_model_code_field($product_id) {
    if (!isset($_POST['_x24_model_code'])) {
        return;
    }

    update_post_meta(
        $product_id,
        '_x24_model_code',
        sanitize_text_field(wp_unslash($_POST['_x24_model_code']))
    );
}

function x24_clean_product_text($text) {
    return trim(str_replace(array('–', '—'), '-', (string) $text));
}

function x24_get_product_model_code($product) {
    $saved_code = x24_clean_product_text($product->get_meta('_x24_model_code', true));
    if ($saved_code !== '') {
        return $saved_code;
    }

    $title = x24_clean_product_text($product->get_name());
    if (preg_match('/\bX24[\s-]*CB[\s-]*(\d{2,4})\b/iu', $title, $matches)) {
        return 'X24-CB-' . $matches[1];
    }

    return sprintf('X24-CB-%03d', (int) $product->get_id() % 1000);
}

function x24_get_product_subtitle($product, $model_code) {
    $subtitle = x24_clean_product_text($product->get_name());
    $subtitle = preg_replace('/^Áo\s+Chạy\s+Bộ(?:\s+Nam|\s+Nữ)?\s*/iu', '', $subtitle);
    $subtitle = str_ireplace($model_code, '', $subtitle);
    $subtitle = trim((string) $subtitle, " \t\n\r\0\x0B-");

    if ($subtitle !== '') {
        return $subtitle;
    }

    $categories = wc_get_product_category_list($product->get_id(), ', ', '', '');
    return $categories !== '' ? wp_strip_all_tags($categories) : 'Thiết kế theo yêu cầu';
}

function x24_get_product_style_label($product) {
    $terms = get_the_terms($product->get_id(), 'product_cat');
    if (!is_wp_error($terms) && !empty($terms)) {
        $label = preg_replace('/^Áo\s+Chạy\s+Bộ\s*/iu', '', $terms[0]->name);
        if ($label !== '') {
            return x24_clean_product_text($label);
        }
    }

    return 'Thiết kế riêng';
}

function x24_product_color_map() {
    return array(
        'cam'       => '#f05a2a',
        'đỏ'        => '#df2029',
        'do'        => '#df2029',
        'vàng'      => '#f3c51d',
        'vang'      => '#f3c51d',
        'xanh lá'   => '#69a83a',
        'xanh la'   => '#69a83a',
        'xanh ngọc' => '#2bb6a8',
        'xanh ngoc' => '#2bb6a8',
        'xanh biển' => '#2679d8',
        'xanh bien' => '#2679d8',
        'xanh'      => '#2679d8',
        'tím'       => '#7656b5',
        'tim'       => '#7656b5',
        'hồng'      => '#e6759e',
        'hong'      => '#e6759e',
        'đen'       => '#27292c',
        'den'       => '#27292c',
        'trắng'     => '#f4f4f1',
        'trang'     => '#f4f4f1',
        'xám'       => '#8b9096',
        'xam'       => '#8b9096',
    );
}

function x24_get_product_colors($product) {
    $colors = array();
    if (taxonomy_exists('pa_mau-sac')) {
        $terms = wc_get_product_terms(
            $product->get_id(),
            'pa_mau-sac',
            array('fields' => 'names')
        );

        if (!is_wp_error($terms)) {
            $colors = array_values(array_filter(array_map('x24_clean_product_text', $terms)));
        }
    }

    if (!empty($colors)) {
        return $colors;
    }

    $title = mb_strtolower(x24_clean_product_text($product->get_name()), 'UTF-8');
    foreach (array_keys(x24_product_color_map()) as $candidate) {
        if (mb_strpos($title, $candidate, 0, 'UTF-8') !== false) {
            return array(mb_convert_case($candidate, MB_CASE_TITLE, 'UTF-8'));
        }
    }

    return array('Theo thiết kế');
}

function x24_get_product_color_hex($color) {
    $key = mb_strtolower(x24_clean_product_text($color), 'UTF-8');
    $map = x24_product_color_map();
    return isset($map[$key]) ? $map[$key] : '#d72f25';
}

add_shortcode('x24_product_colors', 'x24_product_colors_shortcode');
function x24_product_colors_shortcode() {
    if (!is_product()) {
        return '';
    }

    $product = wc_get_product(get_queried_object_id());
    if (!$product instanceof WC_Product) {
        return '';
    }

    $colors = x24_get_product_colors($product);
    ob_start();
    ?>
    <div class="x24-product-colors" aria-label="Màu sắc sản phẩm">
        <?php foreach ($colors as $color) : ?>
            <span class="x24-product-color">
                <span
                    class="x24-product-color__swatch"
                    style="--x24-swatch: <?php echo esc_attr(x24_get_product_color_hex($color)); ?>"
                    aria-hidden="true"
                ></span>
                <span><?php echo esc_html($color); ?></span>
            </span>
        <?php endforeach; ?>
    </div>
    <?php
    return trim((string) ob_get_clean());
}

