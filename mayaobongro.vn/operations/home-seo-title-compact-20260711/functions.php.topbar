/**
 * X24 Sport - SEO Schema Enhancement
 *
 * Sửa đổi schema WooCommerce + Yoast để tối ưu rich results.
 * Không thêm aggregateRating thủ công khi sản phẩm chưa có review thật.
 */

// ============================================================
// 1. BRAND - Thêm thương hiệu vào schema
// ============================================================
add_filter('woocommerce_structured_data_product', 'x24_add_product_brand', 20, 2);
function x24_add_product_brand($markup, $product) {
    $markup['brand'] = [
        '@type' => 'Brand',
        'name'  => 'X24 Sport',
    ];
    return $markup;
}

// ============================================================
// 2. SHIPPING DETAILS - Thông tin vận chuyển
// ============================================================
add_filter('woocommerce_structured_data_product', 'x24_add_shipping_details', 30, 2);
function x24_add_shipping_details($markup, $product) {
    if (isset($markup['offers']) && is_array($markup['offers'])) {
        foreach ($markup['offers'] as &$offer) {
            if (!isset($offer['@type'])) continue;
            $offer['shippingDetails'] = [
                '@type' => 'OfferShippingDetails',
                'shippingRate' => [
                    '@type'    => 'MonetaryAmount',
                    'value'    => '0',
                    'currency' => 'VND',
                ],
                'deliveryTime' => [
                    '@type' => 'ShippingDeliveryTime',
                    'handlingTime' => [
                        '@type'    => 'QuantitativeValue',
                        'minValue' => 3,
                        'maxValue' => 7,
                        'unitCode' => 'DAY',
                    ],
                ],
                'shippingDestination' => [
                    '@type'          => 'DefinedRegion',
                    'addressCountry' => 'VN',
                ],
            ];
        }
    }
    return $markup;
}

