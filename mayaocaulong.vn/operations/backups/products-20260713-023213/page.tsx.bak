            <div>
              <h3 className="text-sm font-semibold uppercase tracking-[0.2em] text-white/55">
                Cam kết dịch vụ
              </h3>
              <div className="mt-5 grid gap-3">
                {[
                  'Thiết kế theo đúng màu đội',
                  'Hỗ trợ đơn số lượng từ nhỏ đến lớn',
