      <section id="process" className="grid items-start gap-6 bg-[var(--ink)] px-[clamp(20px,5vw,72px)] py-[54px] text-white lg:grid-cols-[.8fr_1fr]">
        <div>
          <Sparkles size={24} />
          <h2 className="mt-4 max-w-[720px] text-[clamp(30px,4vw,58px)] leading-none">Tu y tuong den san dau</h2>
