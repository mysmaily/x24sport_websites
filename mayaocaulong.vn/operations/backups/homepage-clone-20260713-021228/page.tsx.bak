      <header className="sticky top-0 z-20 flex h-[72px] items-center justify-between border-b border-[var(--line)] bg-[rgba(248,250,252,.86)] px-[clamp(20px,5vw,72px)] backdrop-blur-[18px]">
        <a className="flex items-center gap-2.5 font-extrabold" href="#">
          <span className="inline-flex h-[34px] w-[34px] items-center justify-center bg-[var(--ink)] text-white">MC</span>
