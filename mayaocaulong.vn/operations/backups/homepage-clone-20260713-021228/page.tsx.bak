          <div className="absolute left-1/2 top-[14%] h-[76px] w-[76px] -translate-x-1/2 rounded-full border-[10px] border-white bg-[var(--lime)]" />
        </div>
      </section>

      <section className="grid grid-cols-1 gap-px border-y border-[var(--line)] px-0 py-0 md:grid-cols-2 xl:grid-cols-4">
