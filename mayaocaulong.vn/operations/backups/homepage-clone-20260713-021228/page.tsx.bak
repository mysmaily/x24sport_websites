      <section className="grid min-h-[calc(100vh-72px)] gap-8 px-[clamp(20px,5vw,72px)] py-[clamp(42px,7vw,86px)] pb-7 lg:grid-cols-[minmax(0,1fr)_minmax(320px,.9fr)]">
        <div className="max-w-[760px] self-center">
          <p className="mb-3 text-xs font-black uppercase text-[var(--accent)]">Custom teamwear / badminton</p>
          <h1 className="mb-6 max-w-[840px] text-[clamp(48px,7vw,112px)] leading-[0.9]">{tenant.brand?.headline}</h1>
          <p className="max-w-[620px] text-xl leading-[1.6] text-[var(--muted)]">{tenant.brand?.subheadline}</p>
          <div className="mt-[30px] flex flex-wrap gap-3">
            <a className="inline-flex min-h-[42px] items-center gap-2 border border-[var(--accent)] bg-[var(--accent)] px-[18px] font-extrabold text-white" href="#products">
              Xem mau ao <ArrowRight size={18} />
            </a>
            <a className="inline-flex min-h-[42px] items-center gap-2 border border-[var(--line)] bg-white px-[18px] text-[var(--ink)]" href="#process">
              Nhan tu van
            </a>
