        >
          <div className="absolute left-[10%] top-[20%] flex h-[210px] w-[170px] rotate-[-9deg] items-center justify-center bg-[var(--ink)] text-5xl font-black text-[var(--lime)] [clip-path:polygon(18%_0,36%_0,43%_12%,57%_12%,64%_0,82%_0,100%_22%,82%_38%,82%_100%,18%_100%,18%_38%,0_22%)] md:h-[280px] md:w-[230px]">
            <span>08</span>
          </div>
          <div className="absolute right-[10%] top-[35%] flex h-[210px] w-[170px] rotate-[8deg] items-center justify-center bg-[var(--accent)] text-5xl font-black text-white [clip-path:polygon(18%_0,36%_0,43%_12%,57%_12%,64%_0,82%_0,100%_22%,82%_38%,82%_100%,18%_100%,18%_38%,0_22%)] md:h-[280px] md:w-[230px]">
            <span>CLB</span>
