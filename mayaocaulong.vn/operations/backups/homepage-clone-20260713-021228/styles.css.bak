@import "tailwindcss";

:root {
  --ink: #111827;
  --muted: #697386;
  --paper: #f8fafc;
  --line: #dce5ef;
  --accent: #f43f5e;
  --lime: #c8ff5f;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  background: var(--paper);
  color: var(--ink);
  font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

a {
  color: inherit;
  text-decoration: none;
}

img {
  display: block;
  max-width: 100%;
}

.product-page {
  min-height: 100vh;
}

.product-shell {
  padding: clamp(20px, 5vw, 72px);
}

.product-crumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  color: var(--muted);
  font-size: 14px;
  margin-bottom: 24px;
}

.product-hero {
  display: grid;
  gap: 24px;
  align-items: start;
}

.product-gallery-card,
.product-copy-card,
.product-side-card {
  border: 1px solid var(--line);
  background: white;
}

.product-gallery-card {
  overflow: hidden;
  background:
    radial-gradient(circle at top right, rgba(244, 63, 94, 0.12), transparent 36%),
    linear-gradient(180deg, #fff8fa 0%, #ffffff 42%);
}

.product-main-image {
  width: 100%;
  height: auto;
  aspect-ratio: 1 / 1;
  object-fit: cover;
}

.product-image-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 480px;
  padding: 40px;
  text-align: center;
  font-size: clamp(24px, 4vw, 48px);
  font-weight: 800;
}

.product-summary {
  border: 1px solid var(--line);
  background: white;
  padding: clamp(24px, 4vw, 42px);
}

.product-kicker,
.section-label {
  margin: 0 0 12px;
  color: var(--accent);
  font-size: 12px;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.product-summary h1 {
  margin: 0;
  font-size: clamp(34px, 5vw, 62px);
  line-height: 0.95;
}

.product-short {
  margin: 18px 0 0;
  color: var(--muted);
  font-size: 18px;
  line-height: 1.7;
}

.product-price-block {
  display: flex;
  align-items: baseline;
  gap: 14px;
  margin-top: 28px;
}

.product-price-block strong {
  font-size: clamp(32px, 4vw, 44px);
}

.product-price-block span {
  color: var(--muted);
  text-decoration: line-through;
  font-size: 18px;
}

.product-meta {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-top: 28px;
}

.product-meta div {
  border: 1px solid var(--line);
  padding: 16px;
  background: #fbfdff;
}

.product-meta span {
  display: block;
  margin-bottom: 8px;
  color: var(--muted);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.product-meta strong {
  font-size: 16px;
}

.product-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 20px;
}

.product-badges span {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 0 14px;
  background: #ffe5ec;
  color: var(--accent);
  font-size: 13px;
  font-weight: 800;
}

.product-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 28px;
}

.product-primary-action,
.product-secondary-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46px;
  padding: 0 18px;
  font-weight: 800;
  border: 1px solid var(--line);
}

.product-primary-action {
  background: var(--accent);
  border-color: var(--accent);
  color: white;
}

.product-secondary-action {
  background: white;
}

.product-trust-list {
  display: grid;
  gap: 12px;
  margin: 28px 0 0;
  padding: 0;
  list-style: none;
}

.product-trust-list li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  color: var(--muted);
  line-height: 1.6;
}

.product-content-grid {
  display: grid;
  gap: 24px;
  margin-top: 24px;
}

.product-copy-card,
.product-side-card {
  padding: clamp(24px, 4vw, 34px);
}

.product-copy-flow {
  display: grid;
  gap: 16px;
}

.product-copy-flow p,
.product-side-card li {
  margin: 0;
  color: var(--muted);
  line-height: 1.8;
}

.product-side-card ul {
  margin: 0;
  padding-left: 18px;
  display: grid;
  gap: 12px;
}

@media (min-width: 960px) {
  .product-hero {
    grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
  }

  .product-content-grid {
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
  }
}

@media (max-width: 720px) {
  .product-meta {
    grid-template-columns: 1fr;
  }

  .product-summary h1 {
    line-height: 1.02;
  }
}
